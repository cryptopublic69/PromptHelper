{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptHelper",
  "version": "5.0.0",
  "identifier": "com.raydio.prompthelper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PromptHelper · 提示词工作台",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "center": true,
        "decorations": false,
        "backgroundColor": "#0b1018"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
